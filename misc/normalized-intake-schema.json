{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestForge Normalized Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceType",
    "experienceProfile",
    "rawSummary",
    "toneTags",
    "playstyleTags",
    "complexityTags",
    "preferenceTags",
    "avoidanceTags",
    "genreTags",
    "ambiguities",
    "confidenceNotes"
  ],
  "properties": {
    "sourceType": {
      "type": "string",
      "enum": [
        "consult_notes",
        "form_response",
        "manual_entry"
      ]
    },
    "experienceProfile": {
      "type": "string",
      "enum": [
        "consult_notes",
        "form_response",
        "manual_entry"
      ]
    },
    "rawSummary": {
      "type": "string",
      "minLength": 1
    },
    "toneTags": {
      "type": "array",
      "items": { "$ref": "#/$defs/weightedToneTag" }
    },
    "playstyleTags": {
      "type": "array",
      "items": { "$ref": "#/$defs/weightedPlaystyleTag" }
    },
    "complexityTags": {
      "type": "array",
      "items": { "$ref": "#/$defs/weightedComplexityTag" }
    },
    "preferenceTags": {
      "type": "array",
      "items": { "$ref": "#/$defs/weightedPreferenceTag" }
    },
    "avoidanceTags": {
      "type": "array",
      "items": { "$ref": "#/$defs/weightedAvoidanceTag" }
    },
    "genreTags": {
      "type": "array",
      "items": { "$ref": "#/$defs/weightedGenreTag" }
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidenceNotes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "weightedTagBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "weight"],
      "properties": {
        "tag": {
          "type": "string"
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "weightedToneTag": {
      "allOf": [
        { "$ref": "#/$defs/weightedTagBase" },
        {
          "properties": {
            "tag": {
              "enum": [
                "mythic",
                "grim",
                "hopeful",
                "eerie",
                "heroic",
                "intimate",
                "epic",
                "mysterious",
                "political",
                "cozy",
                "tense",
                "tragic",
                "wondrous",
                "desperate",
                "adventurous"
              ]
            }
          }
        }
      ]
    },
    "weightedPlaystyleTag": {
      "allOf": [
        { "$ref": "#/$defs/weightedTagBase" },
        {
          "properties": {
            "tag": {
              "enum": [
                "roleplay",
                "character_drama",
                "mystery",
                "exploration",
                "setpiece_combat",
                "tactical_combat",
                "survival",
                "faction_play",
                "mission_loop",
                "sandbox",
                "investigation",
                "social_intrigue",
                "puzzle_solving",
                "cinematic_action",
                "base_building"
              ]
            }
          }
        }
      ]
    },
    "weightedComplexityTag": {
      "allOf": [
        { "$ref": "#/$defs/weightedTagBase" },
        {
          "properties": {
            "tag": {
              "enum": [
                "beginner_friendly",
                "light",
                "medium",
                "crunchy",
                "tactical_heavy",
                "narrative_heavy"
              ]
            }
          }
        }
      ]
    },
    "weightedPreferenceTag": {
      "allOf": [
        { "$ref": "#/$defs/weightedTagBase" },
        {
          "properties": {
            "tag": {
              "enum": [
                "home_base",
                "boss_fights",
                "ruins",
                "travel",
                "faction_tension",
                "moral_choices",
                "big_setpieces",
                "emotional_arcs",
                "ancient_secrets",
                "horror_elements",
                "collaborative_worldbuilding",
                "sacred_imagery",
                "military_structure",
                "weird_magic",
                "monster_hunting",
                "mystery_reveals",
                "political_conflict",
                "heroic_sacrifice",
                "survival_pressure",
                "player_agency"
              ]
            }
          }
        }
      ]
    },
    "weightedAvoidanceTag": {
      "allOf": [
        { "$ref": "#/$defs/weightedTagBase" },
        {
          "properties": {
            "tag": {
              "enum": [
                "grimdark",
                "excessive_gore",
                "body_horror",
                "pvp",
                "betrayal_play",
                "rules_overload",
                "combat_only",
                "hopeless_tone",
                "heavy_politics",
                "sexual_content",
                "graphic_violence",
                "comedy_focus",
                "railroaded_play"
              ]
            }
          }
        }
      ]
    },
    "weightedGenreTag": {
      "allOf": [
        { "$ref": "#/$defs/weightedTagBase" },
        {
          "properties": {
            "tag": {
              "enum": [
                "norse",
                "dark_fantasy",
                "heroic_fantasy",
                "eldritch",
                "frontier",
                "post_apocalyptic",
                "sci_fi",
                "gothic",
                "fairy_tale",
                "sword_and_sorcery",
                "mystery_fantasy",
                "survival_fantasy",
                "mythic_fantasy",
                "urban_fantasy",
                "cosmic_horror"
              ]
            }
          }
        }
      ]
    }
  }
}